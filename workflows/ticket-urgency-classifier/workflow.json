    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"priority\": \"P1\",\n  \"urgency\": \"alta\",\n  \"impact\": \"alto\",\n  \"sentiment\": \"negativo\",\n  \"main_issue\": \"Falha crítica no checkout com impacto comercial.\",\n  \"recommended_routing\": \"Encaminhar para time responsável imediatamente.\",\n  \"triage_notes\": \"Notas curtas para a fila operacional.\"\n}"
      },
      "id": "d4ecdd55-9588-48c4-9f2a-36062cd61338",
