      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -400,
        20
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Classifique o ticket abaixo para triagem inicial de suporte.\n\nTicket: {{ $json.ticket_id }}\nCliente: {{ $json.customer_name }}\nOrigem: {{ $json.source }}\nPlano atual: {{ $json.current_plan }}\nUsuários afetados: {{ $json.reported_users_affected }}\nAssunto: {{ $json.subject }}\nDescrição: {{ $json.description }}\n\nRegras:\n- Responda em português do Brasil.\n- Classifique prioridade como P1, P2, P3 ou P4.\n- Classifique urgência como baixa, média ou alta.\n- Classifique impacto como baixo, médio ou alto.\n- Classifique sentimento como positivo, neutro ou negativo.\n- Descreva o problema principal em linguagem executiva curta.\n- Sugira o encaminhamento operacional mais adequado.\n- Adicione notas curtas de triagem.\n- Não invente fatos não presentes no ticket.",
        "hasOutputParser": true
      },
      "id": "827d95bb-c2f5-455e-af1c-f8d1af3961d5",
      "name": "Basic LLM Chain",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
